  {
    "key": "voter_intelligence.message_variants",
    "label": "Voter Intelligence: Message Variants (Fuel Subsidy)",
    "editable": false,
    "data": {
      "talking_point": "Bello will restore the fuel subsidy for the poorest 40% of Nigerians",
      "cluster_1": {
        "cluster_name": "Persuadable Urban South-West Youth",
        "variants": [
          { "id": 1, "text": "Bello's plan puts ₦18,000/month back in the pockets of the 40% who need it most — not oil traders.", "disclaimer": false },
          { "id": 2, "text": "While others talk, AFP has a number: 40% of Nigerians get direct subsidy relief from day one.", "disclaimer": false },
          { "id": 3, "text": "The subsidy wasn't the problem. Who it went to was. Bello fixes the targeting, not the people.", "disclaimer": true },
          { "id": 4, "text": "No more subsidy for the rich. Under AFP, fuel relief goes to those earning below ₦150k/month — automatically.", "disclaimer": false },
          { "id": 5, "text": "Bello 2027: restore the subsidy where it belongs — the bottom 40%, verified by BVN.", "disclaimer": false }
        ]
      },
      "cluster_2": {
        "cluster_name": "Rural North-West Party-Loyal",
        "variants": [
          { "id": 1, "text": "Bello ya yi alkawari: tallafin mai zai koma ga talakawa 40% — ba 'yan kasuwa ba.", "disclaimer": false },
          { "id": 2, "text": "AFP ta san ciwon talaka. Zai mayar da tallafin man fetur ga waɗanda suka cancanta.", "disclaimer": false },
          { "id": 3, "text": "Ba siyasa ba ce — lissafi ne. Kashi 40 cikin ɗari na Najeriya za su sami tallafi kai tsaye.", "disclaimer": true },
          { "id": 4, "text": "Bello: man fetur mai araha ga iyalai masu ƙarancin kuɗi — farawa daga rana ta farko.", "disclaimer": false },
          { "id": 5, "text": "Tallafi ba ya tafiya zuwa manyan kamfanoni. Yana zuwa gidanku. Wannan alkawarin AFP ne.", "disclaimer": false }
        ]
      },
      "cluster_3": {
        "cluster_name": "South-East Mobilised Opposition",
        "variants": [
          { "id": 1, "text": "Ndi Igbo deserve a president who sees them. Bello's fuel plan puts real money back in Aba, Onitsha and Owerri markets — starting day one.", "disclaimer": false },
          { "id": 2, "text": "40% of Nigerians left behind by the subsidy removal. Bello's plan: targeted cash relief, no brokers, no middlemen.", "disclaimer": false },
          { "id": 3, "text": "The South-East was hardest hit by fuel prices. AFP's targeted subsidy plan starts with the states that suffered most.", "disclaimer": true },
          { "id": 4, "text": "Market women, traders, transporters — the 40% who carry this economy deserve fuel they can afford. Bello's plan delivers.", "disclaimer": false },
          { "id": 5, "text": "Not another empty promise. AFP has the BVN infrastructure to put subsidy relief directly in your account — not through government agents.", "disclaimer": false }
        ]
      },
      "cluster_4": {
        "cluster_name": "Middle Belt Swing",
        "variants": [
          { "id": 1, "text": "Farmers in Benue, Plateau and Taraba spend the most on diesel for pumps and tractors. Bello's plan caps their fuel costs in year one.", "disclaimer": false },
          { "id": 2, "text": "The Middle Belt sacrificed most during the subsidy removal. AFP's targeted plan starts recovery here.", "disclaimer": false },
          { "id": 3, "text": "Transport costs drove food prices up 80% in rural communities. Bello reverses that with a targeted subsidy that works.", "disclaimer": true },
          { "id": 4, "text": "40% of Nigerians. That's every farmer, teacher, and trader who earns below ₦150k. AFP's subsidy plan covers them all.", "disclaimer": false },
          { "id": 5, "text": "When the subsidy was removed, your transport costs doubled. Under AFP, Bello brings targeted relief — verified, direct, no leakage.", "disclaimer": false }
        ]
      },
      "cluster_5": {
        "cluster_name": "Urban North-Central Professionals",
        "variants": [
          { "id": 1, "text": "Smart policy, not populism: AFP's targeted subsidy reaches the bottom 40% via BVN — the same infrastructure we use for tax ID.", "disclaimer": false },
          { "id": 2, "text": "Bello's fuel subsidy is means-tested, BVN-verified, and capped — a fiscal model that works without blowing the budget.", "disclaimer": false },
          { "id": 3, "text": "The old subsidy was a leaking pipe. Bello installs a smart valve — 40% of Nigerians get relief, not oil companies.", "disclaimer": true },
          { "id": 4, "text": "For Abuja professionals who know the numbers: AFP's subsidy plan is ₦1.2tn targeted vs ₦4.7tn blanket. That's the difference.", "disclaimer": false },
          { "id": 5, "text": "Evidence-based governance. AFP's subsidy plan is modelled on Brazil's Bolsa Família — adapted for Nigeria's BVN infrastructure.", "disclaimer": false }
        ]
      }
    }
