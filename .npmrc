auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false

# Refuse to install any package version published less than 7 days ago.
# pnpm 9.15+: minimumReleaseAge takes a duration in minutes. 10080 = 7 days.
# Reasoning: prevents fresh-malicious-publish supply-chain attacks (a class of
# incident that's recurred across the npm ecosystem) by giving the community a
# week to surface compromised releases before we pull them.
minimum-release-age=10080
